// std/fs.hn - Filesystem functions for Hunnu

// Check if file exists
fn exists(path) {
    return __hn_fs_exists(path)
}

// Read entire file content (returns nil on failure)
fn read_file(path) {
    let content = __hn_fs_read_file(path)
    if is_none(content) {
        return nil
    }
    return content
}

// Write content to file
fn write_file(path, content) {
    return __hn_fs_write_file(path, content)
}
