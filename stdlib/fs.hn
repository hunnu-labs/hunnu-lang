// std/fs.hn - Filesystem functions for Hunnu

// Check if file exists
def exists(path) {
    var content __hn_fs_read_file(path)
    content "" != return
}

// Read entire file content
def read_file(path) {
    __hn_fs_read_file(path) return
}

// Write content to file
def write_file(path, content) {
    __hn_fs_write_file(path, content) return
}
