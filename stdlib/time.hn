// std/time.hn - Time functions for Hunnu
// Uses FFI to C standard library

// Get current time in seconds since epoch
extern fn time(t) -> int from "libc.so.6"

// Sleep for n seconds
extern fn sleep(seconds) -> int from "libc.so.6"

// Get current timestamp
fn now() {
    return time(0)
}

// Formatted date-time string (YYYY-MM-DD HH:MM:SS)
fn timestamp() {
    let t = time(0)
    return __hn_time_format(t)
}
