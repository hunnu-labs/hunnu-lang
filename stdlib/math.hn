// std.math - Math standard library for Hunnu
// Provides common mathematical functions via FFI

// Power function
extern def pow(base, exp) -> float from "libm.so.6"

// Square root
extern def sqrt(x) -> float from "libm.so.6"

// Trigonometric functions
extern def sin(x) -> float from "libm.so.6"
extern def cos(x) -> float from "libm.so.6"
extern def tan(x) -> float from "libm.so.6"

// Absolute value
extern def fabs(x) -> float from "libm.so.6"
