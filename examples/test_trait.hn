trait Area {
    def area(self)
    def describe(self)
}

class Circle {
    pub radius: int

    def new(self, r) {
        self.radius r =
    }
}

class Rect {
    pub w: int
    pub h: int

    def new(self, w, h) {
        self.w w =
        self.h h =
    }
}

impl Area for Circle {
    def area(self) {
        return 3 self.radius * self.radius *
    }

    def describe(self) {
        print("Circle")
    }
}

impl Area for Rect {
    def area(self) {
        return self.w self.h *
    }

    def describe(self) {
        print("Rectangle")
    }
}

def main() {
    var c new Circle(5)
    c.describe()
    print(c.area())

    var r new Rect(3, 4)
    r.describe()
    print(r.area())
}
