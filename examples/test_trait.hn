trait Area {
    fn area(self)
    fn describe(self)
}

class Circle {
    pub radius: int

    fn new(self, r) {
        self.radius = r
    }
}

class Rect {
    pub w: int
    pub h: int

    fn new(self, w, h) {
        self.w = w
        self.h = h
    }
}

impl Area for Circle {
    fn area(self) {
        return 3 * self.radius * self.radius
    }

    fn describe(self) {
        print("Circle")
    }
}

impl Area for Rect {
    fn area(self) {
        return self.w * self.h
    }

    fn describe(self) {
        print("Rectangle")
    }
}

fn main() {
    let c = new Circle(5)
    c.describe()
    print(c.area())

    let r = new Rect(3, 4)
    r.describe()
    print(r.area())
}
