def main() {
    class Point {
        pub x: int
        pub y: int

        def new(self, x, y) {
            self.x x =
            self.y y =
        }

        def length(self) {
            return self.x self.x * self.y self.y * +
        }
    }

    var p new Point(3, 4)
    print(p.x)
    print(p.y)
    var len p.length()
    print(len)
}
