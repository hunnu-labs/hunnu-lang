fn main() {
    class Point {
        pub x: int
        pub y: int

        fn new(self, x, y) {
            self.x = x
            self.y = y
        }

        fn length(self) {
            return self.x * self.x + self.y * self.y
        }
    }

    let p = new Point(3, 4)
    print(p.x)
    print(p.y)
    let len = p.length()
    print(len)
}
