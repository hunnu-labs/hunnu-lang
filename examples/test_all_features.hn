// Feature 1: Unsafe blocks (#29)
def test_unsafe() {
    var x 42
    unsafe {
        var y x 8 +
        print(y)
    }
}

// Feature 2: Module visibility with pub (#30)
pub def public_helper() {
    print("public")
}

def private_helper() {
    print("private")
}

// Feature 3: Enums/ADTs (#27)
enum Option {
    Some(val),
    None
}

enum Color {
    Red,
    Green,
    Blue(r, g, b)
}

def test_enums() {
    var c Color::Red
    print(c)

    var rgb Color::Blue(255, 128, 0)
    print(rgb)

    match rgb {
        Color::Red => { print("matched red") }
        Color::Green => { print("matched green") }
        Color::Blue(r_val, g_val, b_val) => {
            print(r_val)
            print(g_val)
            print(b_val)
        }
        _ => { print("unknown") }
    }
}

// Feature 4: Generics (#28)
def identity<T>(x) {
    return x
}

def main() {
    print("--- unsafe ---")
    test_unsafe()

    print("--- pub/priv ---")
    public_helper()
    private_helper()

    print("--- enums ---")
    test_enums()

    print("--- generics ---")
    var v identity(42)
    print(v)
    var s identity("hello")
    print(s)
}
