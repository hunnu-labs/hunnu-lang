def main() {
    class Shape {
        pub name: str

        def new(self, name) {
            self.name name =
        }

        def area(self) {
            return 0
        }

        def describe(self) {
            return self.name
        }
    }

    class Circle : Shape {
        pub radius: int

        def new(self, name, r) {
            self.name name =
            self.radius r =
        }

        def area(self) {
            return 3 self.radius * self.radius *
        }
    }

    class Rectangle : Shape {
        pub w: int
        pub h: int

        def new(self, name, w, h) {
            self.name name =
            self.w w =
            self.h h =
        }

        def area(self) {
            return self.w self.h *
        }
    }

    var c new Circle("Circle A", 5)
    print(c.describe())
    print(c.area())

    var r new Rectangle("Rect B", 3, 4)
    print(r.describe())
    print(r.area())
}
