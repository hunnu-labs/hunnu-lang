// Test calling Rust functions via FFI
extern def hunnu_math_square(x) -> int from "vm-rust/target/release/libhunnu_vm.so"
extern def hunnu_math_add(a, b) -> int from "vm-rust/target/release/libhunnu_vm.so"
extern def hunnu_get_greeting() -> str from "vm-rust/target/release/libhunnu_vm.so"

def main() {
    var sq hunnu_math_square(5)
    print(sq)
    
    var sum hunnu_math_add(10, 20)
    print(sum)
    
    var greeting hunnu_get_greeting()
    print(greeting)
}
